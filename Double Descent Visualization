import numpy as np
import matplotlib.pyplot as plt
from sklearn.preprocessing import PolynomialFeatures
from sklearn.linear_model import LinearRegression, Ridge
from sklearn.metrics import mean_squared_error
from sklearn.model_selection import train_test_split


#Fazla veri ve az gürültü

np.random.seed(42)
n_samples=200
X=np.linspace(-1,1,n_samples)
y=X**2+0.05*np.random.randn(n_samples)


X_train,X_test,y_train, y_test = train_test_split(X.reshape(-1,1),y,test_size=0.5,random_state=42)

degrees = np.arange(1,101)
train_mse_lin, test_mse_lin = [],[]
train_mse_ridge, test_mse_ridge = [],[]

for d in degrees:
    poly = PolynomialFeatures(degree=d)
    X_train_poly = poly.fit_transform(X_train)
    X_test_poly = poly.fit_transform(X_test)

    lin = LinearRegression()
    lin.fit(X_train_poly,y_train)
    train_mse_lin.append(mean_squared_error(y_train,lin.predict(X_train_poly)))
    test_mse_lin.append(mean_squared_error(y_test,lin.predict(X_test_poly)))

    ridge = Ridge(alpha=1.0)
    ridge.fit(X_train_poly,y_train)
    train_mse_ridge.append(mean_squared_error(y_train,ridge.predict(X_train_poly)))
    test_mse_ridge.append(mean_squared_error(y_test,ridge.predict(X_test_poly)))

plt.figure(figsize=(12, 6))
plt.plot(degrees, test_mse_lin, label='LinearRegression Test Hatası (Double Descent)',
             color='red')
plt.plot(degrees, test_mse_ridge, label='Ridge Test Hatası (Klasik U-eğrisi)', color='blue')
plt.axvline(x=len(X_train), color='gray', linestyle='--',label=f'Enterpolasyon Eşiği(m={len(X_train)})')
plt.yscale('log')
plt.xlabel('Polinom Derecesi')
plt.ylabel('Test Hatası (MSE - Log Ölçek)')
plt.title('Linear vs Ridge: Double Descent ve Klasik U-eğrisi')
plt.legend()
plt.grid(True, which="both", ls="-", alpha=0.3)
plt.show()
