#Derece 1(Underfitting): Model sadece düz bir çizgi çekebildiği için kosinüs eğirisinin daireselliğini yakalayamaz.Yüksek yanlılık nedeniyle hata oranı oldukça yüksektir
#Derece 4(İdeal):İşte bizim istediğimiz derece budur. Model verinin genel eğimini başarıyla kapsar böylelikle Gürültüden ziyade sinyale odaklandığı için hem eğitim hem test verisinde düşük hata üretir
#Derece 15(Overfitting):Model her gürültülü noktayı tek tek ziyaret etmeye çalışacak.Bu aşırı esneklik eğitim verisinde hatayı sıfıra yaklaştırsa da, genel yapıyı bozduğu için genelleme yeteneğini yok eder.


import numpy as np
import matplotlib.pyplot as plt
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import PolynomialFeatures
from sklearn.linear_model import LinearRegression
from sklearn.model_selection import cross_val_score

def true_fun(X):
    return np.cos(1.5*np.pi*X)
#Sentetik veri üretimi
np.random.seed(0)
n_samples = 30
X = np.sort(np.random.randn(n_samples))
#Gerçek fonksiyona 0.1 standart sapmalı rastgee gürültü eklemek
y = true_fun(X) + np.random.randn(n_samples)*0.1

degrees = [1,4,15] #Dereceleri belirliyoruz

plt.figure(figsize=(18,6))

for i,degree in enumerate(degrees):
    ax = plt.subplot(1,len(degrees),i+1)
    plt.setp(ax,xticks=(),yticks=())

    #Polinom özelliklerini ve regresyonu bir pipeline içinde birleştiriyoruz.
    #Pipeline kullanımı hem kodun temizliğini sağlar hem de veri sızıntısını önler.

    polynomial_features = PolynomialFeatures(degree=degree, include_bias = False)
    linear_regression = LinearRegression()
    pipeline = Pipeline([
        ("poly_features",polynomial_features),
        ("linear_regression",linear_regression)
    ])

    #Şimdi sıra modeli eğitmekte

    pipeline.fit(X[:, np.newaxis],y)

    #Modeli 10 katlı çapraz doğrulama ile değerlendirelim.
    scores = cross_val_score(pipeline,X[:,np.newaxis],y,
                             scoring='neg_mean_squared_error',cv=10)

    X_test = np.linspace(0,1,100)
    plt.plot(X_test,pipeline.predict(X_test[:,np.newaxis]),label='Model(Tahmin)')
    plt.plot(X_test,true_fun(X_test),label='Gerçek Fonksiyon',linestyle='--')
    plt.scatter(X,y,edgecolor='b',s=30,label='Eğitim Verisi')

    plt.xlabel("x özniteliği")
    plt.ylabel("y hedefi")
    plt.xlim((0,1))
    plt.ylim((-2,2))
    plt.legend(loc='best')
    plt.title(f"Deerece{degree}\nMSE={-scores.mean():.2e}(+/-{scores.std():.2e})")


plt.suptitle("Model Kapasitesinin Görsel Analizi:Underfitting'den Overfitting'e yolculuk",fontsize=16)
plt.tight_layout(rect=[0,0.03,1,0.95])
plt.show()
